   public function update(Request $request){
    
   //dd($request->all());

    $customMessages = [
            'nome.min' => 'Descrição deve ter no min 2 caracteres',
            'nome.max' => 'Descrição deve ter no max 100 caracteres',            
            'nome.required' => 'Campo obrigatório', 
            'habitacao.required' => 'Campo obrigatório', 
        
        ];

        $validatedData = [
            'nome' => 'required|max:100|min:2',
            'habitacao' => 'required',
            
        ];
        $validatedData = $request->validate($validatedData, $customMessages);

        $consulta1 = GrupoTarifa::where('descricao', $request->nome)
        ->where('unidade_habitacional_id', $request->habitacao)
        ->where('id', '<>', $request->id)
        ->count();
        if($consulta1 > 0){
          \Session::flash('message', ['msg'=>"Já existe um grupo com essa descrição e Tipo de UH!", 'class'=>'danger']);
          return redirect()->back();
        }
        //dd($consulta1);
        /*
        $consulta1 = GrupoTarifa::where('descricao', $request->nome)
        ->where('id', '<>', $request->id)
        ->count();

        if($consulta1 > 0){
        	\Session::flash('message', ['msg'=>"Já existe um grupo com essa descrição!", 'class'=>'danger']);
        	return redirect()->back();
        }
        */
        $consulta = GrupoTarifa::find($request->id);
   		  $consulta->descricao = $validatedData['nome'];
        $consulta->unidade_habitacional_id = $validatedData['habitacao'];
        //$consulta->sigla = $validatedData['sigla'];
   	  	$consulta->update();
      
      //$val[] = "";
      if($request->posto){
      foreach ($request->posto as $key => $value) {
        //echo $value. "<br>";
        $val[] = $value;

      }
      $r = $consulta->postos()->sync($val);
    }else{
      $r = $consulta->postos()->detach();
    }
      //var_dump($val);

      
      


   		\Session::flash('message', ['msg'=>"Atualizado com sucesso!", 'class'=>'success']);
   		return redirect()->route('grupo_tarifa.index');
   }
