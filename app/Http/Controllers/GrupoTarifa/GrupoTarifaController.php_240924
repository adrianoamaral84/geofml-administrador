class GrupoTarifaController extends Controller
{
    public function __construct()
    {
        $this->middleware('auth');
    }
    public function index(){
   	$consulta = GrupoTarifa::paginate(20)->sortBy('descricao');
   	return view('grupotarifa.index', compact('consulta'));
   }

   public function edit($id){
    
    $id = Crypt::decrypt($id);
   	
    $consulta = GrupoTarifa::find($id);
    $habitacoes = \App\TipoUndHab::all();

    $postos = \App\PostoGraduacao::all();
    
   	return view('grupotarifa.edit', compact('consulta', 'postos', 'habitacoes'));
   }

   public function delete($id){
    
    
    $id = Crypt::decrypt($id);
   	$consulta = GrupoTarifa::find($id);
   	$consulta->delete();
   	\Session::flash('message', ['msg'=>"Deletado com sucesso!", 'class'=>'success']);
    return redirect()->route('grupo_tarifa.index');
   	
   }

   public function create(){
    

    $postos = \App\PostoGraduacao::all();
    $habitacoes = \App\TipoUndHab::all();

    return view('grupotarifa.create', compact('postos', 'habitacoes'));
   }

