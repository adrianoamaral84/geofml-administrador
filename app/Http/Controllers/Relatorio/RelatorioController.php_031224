        $ano = $validatedData['ano'];
        $data_inicial   =    date($ano . '-01-01');      
        $data_final     =    date($ano . '-12-31');


        $consultaCancelados1 = DB::select("SELECT MONTH(data_inicio) as mes, SUM(valor_pago) as SOMA FROM hospedagem WHERE YEAR(data_inicio) = $ano AND status = 6 AND valor_pago IS NOT NULL GROUP BY MONTH(data_inicio)");

        
