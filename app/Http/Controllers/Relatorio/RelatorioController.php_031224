    public function __construct()
    {
        $this->middleware('auth');
    }


    public function index(){
    
        date_default_timezone_set('America/Sao_Paulo');
        session(['link' => url()->current()]);
        $mes = date('m');
        $ano = date('Y');
        return view('relatorios.index', compact('mes', 'ano'));

    }
    public function verdados($id){
    


        date_default_timezone_set('America/Sao_Paulo');
        $id = Crypt::decrypt($id);
        $hospedagem = \App\Hospede::where('id', $id)->with('user')->first();     

        return view('relatorios.editar_dados', compact('hospedagem'));

        

    }

    public function atualizar(Request $request){

        //dd($request->all());
        date_default_timezone_set('America/Sao_Paulo');
        $customMessages = [

            //'checkin.required' => 'Campo Checkin obrigatório',
            //'checkout.required' => 'Campo Checkout obrigatório',
            //'valor.required' => 'Campo Valor obrigatório',
            //'diarias.required' => 'Campo Diárias obrigatório',
             
        ];


        $validatedData = [
            'checkin'   =>  'nullable',
            'checkout'  =>  'nullable',
            'valor'     =>  'nullable',
            'diarias'   =>  'nullable',  
        ];
       $validatedData = $request->validate($validatedData, $customMessages);
        $hospedagem = \App\Hospede::findOrFail($request->id);

        if(!empty($validatedData['checkout']) AND empty($validatedData['checkin'])){
            \Session::flash('message', ['msg'=>"Não pode salvar o Check-in em BRANCO e o check-out Preenchido!", 'class'=>'danger']);
            return redirect()->back();
        }

        if(empty($validatedData['checkout']) AND !empty($validatedData['checkin'])){
            $checkin = 1;
            $hospedagem->checkin_at     =   $validatedData['checkin'];
            $hospedagem->checkout_at    =   null;

        }
        
        if(empty($validatedData['checkout']) AND empty($validatedData['checkin'])){
            $checkin = null;
            $hospedagem->checkin_at     =   null;
            $hospedagem->checkout_at    =   null; 
        }
        
        if(!empty($validatedData['checkout']) AND !empty($validatedData['checkin'])){
            $checkin = 2;
            $hospedagem->checkin_at     =   $validatedData['checkin'];
            $hospedagem->checkout_at    =   $validatedData['checkout']; 
        }
        
        if(empty($validatedData['valor'])){
            
            $request->valor2 = '';

        }else{
            
            $validatedData['valor'] = str_replace(",",".",str_replace(".","",$validatedData['valor']));
            $validatedData['valor'] = substr($validatedData['valor'], 4);

        }
       
        
        $hospedagem->checkin        =   $checkin;        
        $hospedagem->valor          =   $request->valor2;
        $hospedagem->qntdiarias     =   $validatedData['diarias'];
        $hospedagem->update();
        \Session::flash('message', ['msg'=>"Dados alterados com sucesso!", 'class'=>'success']);
        return redirect()->route('arrecadacao.view');



    }

