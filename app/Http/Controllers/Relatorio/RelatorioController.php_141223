                $hospedagens[] = $value->comprovante->hospedagem_id;

            }


        }
        
        foreach ($hospedagens as $key => $value) {
            $hospedagem[] = \App\Hospede::where('id', $value)->first();
        }
        




        }else{
            
            //$hospedagem = \App\Hospede::where('id', $value)->first();

        }   

        

        
        //dd($hospedagem);
        //$consulta = \App\Comprovante::with('hospedagem')->get();

        //dd($consulta);
        $valor = 0;
        foreach ($consulta as $key => $value) {
            $valor += $value->valortarifa;
        }
        //dd($valor);
        //$object = new stdClass();
        //$object = new \stdClass;
        //$object = (object) $hospedagem;
        //dd($object);
        //$aa =  count($hospedagem);
        //dd($hospedagem);

        return view('relatorios.cancelados_resultado', compact('hospedagem', 'valor'));
        
    }
